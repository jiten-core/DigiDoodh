{
    "name": "digidhoodh-ultimate",
    "version": "2.0.0",
    "description": "DigiDhoodh - Complete Dairy Management SaaS for India",
    "private": true,
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:migrate": "prisma migrate dev",
        "electron:dev": "concurrently \"cross-env NODE_ENV=development npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
        "electron:build": "npm run build && electron-builder",
        "electron:build:win": "npm run build && electron-builder --win",
        "electron:build:mac": "npm run build && electron-builder --mac",
        "electron:build:linux": "npm run build && electron-builder --linux",
        "prepare": "prisma generate"
    },
    "dependencies": {
        "@hookform/resolvers": "^3.3.4",
        "@prisma/client": "^5.8.0",
        "@radix-ui/react-accordion": "^1.1.2",
        "@radix-ui/react-alert-dialog": "^1.0.5",
        "@radix-ui/react-aspect-ratio": "^1.1.8",
        "@radix-ui/react-avatar": "^1.0.4",
        "@radix-ui/react-checkbox": "^1.0.4",
        "@radix-ui/react-collapsible": "^1.0.3",
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.0.5",
        "@radix-ui/react-dropdown-menu": "^2.0.6",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-label": "^2.0.2",
        "@radix-ui/react-menubar": "^1.1.16",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-popover": "^1.0.7",
        "@radix-ui/react-progress": "^1.0.3",
        "@radix-ui/react-radio-group": "^1.1.3",
        "@radix-ui/react-scroll-area": "^1.0.5",
        "@radix-ui/react-select": "^2.0.0",
        "@radix-ui/react-separator": "^1.0.3",
        "@radix-ui/react-slider": "^1.1.2",
        "@radix-ui/react-slot": "^1.0.2",
        "@radix-ui/react-switch": "^1.0.3",
        "@radix-ui/react-tabs": "^1.0.4",
        "@radix-ui/react-toast": "^1.1.5",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.0.7",
        "@supabase/ssr": "^0.8.0",
        "@supabase/supabase-js": "^2.39.0",
        "@tanstack/react-query": "^5.17.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.0",
        "cmdk": "^1.1.1",
        "date-fns": "^3.2.0",
        "dexie": "^4.3.0",
        "dexie-react-hooks": "^4.2.0",
        "electron-squirrel-startup": "^1.0.1",
        "embla-carousel-react": "^8.6.0",
        "i18next": "^23.7.11",
        "input-otp": "^1.4.2",
        "jspdf": "^2.5.1",
        "jspdf-autotable": "^3.8.1",
        "lucide-react": "^0.309.0",
        "next": "^16.1.4",
        "next-pwa": "^5.6.0",
        "next-themes": "^0.4.6",
        "qrcode": "^1.5.3",
        "razorpay": "^2.9.2",
        "react": "^19.2.3",
        "react-day-picker": "^9.13.0",
        "react-dom": "^19.2.3",
        "react-hook-form": "^7.49.2",
        "react-i18next": "^14.0.0",
        "react-qr-code": "^2.0.12",
        "react-resizable-panels": "^4.5.3",
        "recharts": "^3.7.0",
        "sonner": "^1.3.1",
        "tailwind-merge": "^2.2.0",
        "tailwindcss-animate": "^1.0.7",
        "ultracontext": "^1.0.1",
        "vaul": "^1.1.2",
        "zod": "^3.22.4",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@testing-library/jest-dom": "^6.2.0",
        "@testing-library/react": "^14.1.2",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.6",
        "@types/react": "^19.2.9",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "cross-env": "^10.1.0",
        "electron": "^28.1.0",
        "electron-builder": "^24.9.1",
        "eslint": "^9.0.0",
        "eslint-config-next": "^16.1.4",
        "framer-motion": "^12.29.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.4.33",
        "prisma": "^5.8.0",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.3.3",
        "wait-on": "^7.2.0"
    },
    "author": "Jiten",
    "build": {
        "appId": "com.digidhoodh.app",
        "productName": "DigiDhoodh",
        "copyright": "Copyright © 2026 DigiDhoodh",
        "directories": {
            "output": "dist",
            "buildResources": "electron/resources"
        },
        "files": [
            "electron/**/*",
            "out/**/*",
            "!electron/icons/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "electron/icons",
                "to": "icons",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "electron/icons/icon.ico",
            "artifactName": "${productName}-${version}-Windows-Setup.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "DigiDhoodh"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "electron/icons/icon.icns",
            "category": "public.app-category.business",
            "artifactName": "${productName}-${version}-macOS.${ext}"
        },
        "dmg": {
            "title": "${productName} ${version}",
            "icon": "electron/icons/icon.icns"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "electron/icons",
            "category": "Office",
            "artifactName": "${productName}-${version}-Linux.${ext}"
        }
    }
}