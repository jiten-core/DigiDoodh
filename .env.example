# DigiDhoodh Ultimate Environment Variables
# Copy this file to .env.local and fill in your values

# ==============================================
# SUPABASE (Primary Database)
# ==============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==============================================
# DATABASE (Prisma - Points to Supabase)
# ==============================================
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ==============================================
# AUTHENTICATION
# ==============================================
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ==============================================
# PAYMENT GATEWAY (Razorpay)
# ==============================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ==============================================
# WHATSAPP INTEGRATION (Optional)
# ==============================================
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_BUSINESS_ID=your_business_id

# ==============================================
# SMS GATEWAY (Optional - for OTP fallback)
# ==============================================
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=DGDOOD

# ==============================================
# STORAGE (Supabase Storage)
# ==============================================
STORAGE_BUCKET=digidhoodh-files

# ==============================================
# APPLICATION
# ==============================================
NEXT_PUBLIC_APP_NAME=DigiDhoodh
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@digidhoodh.com
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210

# ==============================================
# ANALYTICS (Optional)
# ==============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================
# ELECTRON (Desktop App)
# ==============================================
ELECTRON_START_URL=http://localhost:3000
