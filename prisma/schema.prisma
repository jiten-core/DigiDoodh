// DigiDhoodh Ultimate - Complete Database Schema
// Merged from Project 3 with PRD v2.0 compliance
// Primary Database: Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USER MANAGEMENT
// ============================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?  @unique
  password    String
  name        String
  role        UserRole @default(FARMER)
  avatar      String?
  language    String   @default("en") // Multi-language support
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  fcmToken    String?  // Push notifications
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  dairy       Dairy?
  farmer      Farmer?
  staff       Staff?
  superAdmin  SuperAdmin?
  buyer       Buyer?

  @@map("users")
}

enum UserRole {
  PLATFORM_SUPER_ADMIN  // God mode
  INTERNAL_SUPER_ADMIN  // Support & audit
  DAIRY_OWNER           // Paying customer
  STAFF                 // Operations role
  FARMER                // Free, view-only
  BUYER                 // Purchases milk/products
}

// ============================================
// DAIRY (Main Business Entity)
// ============================================

model Dairy {
  id              String      @id @default(cuid())
  name            String
  email           String      @unique
  phone           String
  address         String?
  village         String?
  district        String?
  state           String?
  pincode         String?
  gstNumber       String?     @unique
  panNumber       String?
  logo            String?
  status          DairyStatus @default(ACTIVE)
  planExpiresAt   DateTime?
  whatsappCredits Int         @default(100)
  isKycVerified   Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  
  farmers         Farmer[]
  staff           Staff[]
  buyers          Buyer[]
  milkCollections MilkCollection[]
  rateCharts      RateChart[]
  bills           Bill[]
  products        Product[]
  productSales    ProductSale[]
  inventory       Inventory[]
  notifications   Notification[]
  referrals       Referral[]    @relation("ReferrerDairy")
  referredBy      Referral[]    @relation("ReferredDairy")

  @@map("dairies")
}

enum DairyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

// ============================================
// SUPER ADMIN (Platform Owner)
// ============================================

model SuperAdmin {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  permissions String   // JSON string of permissions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("super_admins")
}

// ============================================
// FARMER PROFILE
// ============================================

model Farmer {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  dairyId      String
  dairy        Dairy     @relation(fields: [dairyId], references: [id])
  farmerCode   String    @unique
  aadharNumber String?   @unique
  bankAccount  String?
  ifsc         String?
  upiId        String?
  address      String?
  village      String?
  qrCode       String?   // QR code for quick identification
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Wallet
  walletBalance  Float    @default(0)
  lastWalletUpdate DateTime?

  // Relations
  milkCollections MilkCollection[]
  loans           Loan[]
  advances        Advance[]
  bills           Bill[]
  cattle          Cattle[]

  @@map("farmers")
}

// ============================================
// STAFF MEMBERS
// ============================================

model Staff {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  dairyId     String
  dairy       Dairy     @relation(fields: [dairyId], references: [id])
  staffCode   String    @unique
  permissions String    // JSON string of permissions
  salary      Float?
  joiningDate DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  milkCollections MilkCollection[]
  attendance      Attendance[]

  @@map("staff")
}

// ============================================
// BUYER (NEW - PRD v2.0)
// ============================================

model Buyer {
  id           String      @id @default(cuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id])
  dairyId      String
  dairy        Dairy       @relation(fields: [dairyId], references: [id])
  buyerCode    String      @unique
  businessName String?
  businessType BuyerBusinessType @default(INDIVIDUAL)
  gstNumber    String?
  licenseNumber String?
  address      String?
  creditLimit  Float       @default(10000)
  outstandingBalance Float @default(0)
  qrCode       String?     // QR code for identification
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Preferences
  invoiceFrequency InvoiceFrequency @default(WEEKLY)
  paymentTerms     String           @default("NET_30")

  // Relations
  orders       BuyerOrder[]
  invoices     BuyerInvoice[]

  @@map("buyers")
}

enum BuyerBusinessType {
  RETAIL
  WHOLESALE
  RESTAURANT
  HOTEL
  INDIVIDUAL
}

enum InvoiceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================
// CATTLE INFORMATION
// ============================================

model Cattle {
  id         String     @id @default(cuid())
  farmerId   String
  farmer     Farmer     @relation(fields: [farmerId], references: [id])
  tagNumber  String     @unique
  type       CattleType
  breed      String?
  birthDate  DateTime?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  milkCollections MilkCollection[]

  @@map("cattle")
}

enum CattleType {
  COW
  BUFFALO
  GOAT
  MIXED
}

// ============================================
// MILK COLLECTION (Core Feature - TIER-0)
// ============================================

model MilkCollection {
  id             String       @id @default(cuid())
  dairyId        String
  dairy          Dairy        @relation(fields: [dairyId], references: [id])
  farmerId       String
  farmer         Farmer       @relation(fields: [farmerId], references: [id])
  cattleId       String?
  cattle         Cattle?      @relation(fields: [cattleId], references: [id])
  staffId        String?
  staff          Staff?       @relation(fields: [staffId], references: [id])
  collectionDate DateTime     @default(now())
  shift          MilkShift
  liters         Float
  fat            Float?
  snf            Float?
  clr            Float?       // Corrected Lactometer Reading
  temperature    Float?
  ratePerLiter   Float
  totalAmount    Float
  quality        MilkQuality  @default(GOOD)
  isSynced       Boolean      @default(true)
  isPaid         Boolean      @default(false)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("milk_collections")
}

enum MilkShift {
  MORNING
  EVENING
}

enum MilkQuality {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
}

// ============================================
// RATE CHARTS
// ============================================

model RateChart {
  id            String     @id @default(cuid())
  dairyId       String
  dairy         Dairy      @relation(fields: [dairyId], references: [id])
  name          String
  cattleType    CattleType
  isActive      Boolean    @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  entries       RateChartEntry[]

  @@map("rate_charts")
}

model RateChartEntry {
  id           String    @id @default(cuid())
  rateChartId  String
  rateChart    RateChart @relation(fields: [rateChartId], references: [id])
  fatMin       Float
  fatMax       Float
  snfMin       Float?
  snfMax       Float?
  ratePerLiter Float
  createdAt    DateTime  @default(now())

  @@map("rate_chart_entries")
}

// ============================================
// BILLING SYSTEM
// ============================================

model Bill {
  id              String        @id @default(cuid())
  dairyId         String
  dairy           Dairy         @relation(fields: [dairyId], references: [id])
  farmerId        String
  farmer          Farmer        @relation(fields: [farmerId], references: [id])
  billNumber      String        @unique
  billingPeriod   BillingPeriod
  startDate       DateTime
  endDate         DateTime
  totalLiters     Float
  totalAmount     Float
  advanceAmount   Float         @default(0)
  loanDeduction   Float         @default(0)
  otherDeductions Float         @default(0)
  netAmount       Float
  taxAmount       Float         @default(0)
  status          BillStatus    @default(DRAFT)
  pdfUrl          String?
  whatsappSent    Boolean       @default(false)
  paidAt          DateTime?
  paymentMethod   PaymentMethod?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("bills")
}

enum BillingPeriod {
  TEN_DAY     // Default for dairy
  MONTHLY
  WEEKLY
  CUSTOM
}

enum BillStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  PARTIALLY_PAID
  CANCELLED
}

// ============================================
// BUYER ORDERS & INVOICES
// ============================================

model BuyerOrder {
  id          String      @id @default(cuid())
  buyerId     String
  buyer       Buyer       @relation(fields: [buyerId], references: [id])
  orderDate   DateTime    @default(now())
  items       Json        // Array of order items
  subtotal    Float
  taxAmount   Float       @default(0)
  totalAmount Float
  status      OrderStatus @default(PENDING)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("buyer_orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

model BuyerInvoice {
  id            String        @id @default(cuid())
  buyerId       String
  buyer         Buyer         @relation(fields: [buyerId], references: [id])
  invoiceNumber String        @unique
  startDate     DateTime
  endDate       DateTime
  items         Json          // Array of invoice items
  subtotal      Float
  taxAmount     Float         @default(0)
  totalAmount   Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime
  paidAt        DateTime?
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("buyer_invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ============================================
// LOANS & ADVANCES
// ============================================

model Loan {
  id          String     @id @default(cuid())
  farmerId    String
  farmer      Farmer     @relation(fields: [farmerId], references: [id])
  amount      Float
  interestRate Float
  emiAmount   Float
  totalEmis   Int
  paidEmis    Int        @default(0)
  status      LoanStatus @default(ACTIVE)
  startDate   DateTime
  nextDueDate DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  repayments  LoanRepayment[]

  @@map("loans")
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

model LoanRepayment {
  id        String        @id @default(cuid())
  loanId    String
  loan      Loan          @relation(fields: [loanId], references: [id])
  amount    Float
  date      DateTime
  method    PaymentMethod
  createdAt DateTime      @default(now())

  @@map("loan_repayments")
}

model Advance {
  id        String        @id @default(cuid())
  farmerId  String
  farmer    Farmer        @relation(fields: [farmerId], references: [id])
  amount    Float
  reason    String?
  status    AdvanceStatus @default(PENDING)
  givenAt   DateTime
  repaidAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("advances")
}

enum AdvanceStatus {
  PENDING
  REPAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

// ============================================
// PRODUCTS & INVENTORY
// ============================================

model Product {
  id          String          @id @default(cuid())
  dairyId     String
  dairy       Dairy           @relation(fields: [dairyId], references: [id])
  name        String
  description String?
  category    ProductCategory
  unit        String          // kg, liters, pieces
  price       Float
  minStock    Float?
  maxStock    Float?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  inventory   Inventory[]
  sales       ProductSale[]

  @@map("products")
}

enum ProductCategory {
  MILK
  GHEE
  BUTTER
  CHEESE
  YOGURT
  CATTLE_FEED
  MEDICINE
  EQUIPMENT
  OTHER
}

model Inventory {
  id           String   @id @default(cuid())
  dairyId      String
  dairy        Dairy    @relation(fields: [dairyId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  currentStock Float
  minStock     Float?
  lastUpdated  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  transactions InventoryTransaction[]

  @@map("inventory")
}

model InventoryTransaction {
  id          String          @id @default(cuid())
  inventoryId String
  inventory   Inventory       @relation(fields: [inventoryId], references: [id])
  type        TransactionType
  quantity    Float
  unitPrice   Float?
  totalValue  Float?
  reason      String?
  createdAt   DateTime        @default(now())

  @@map("inventory_transactions")
}

enum TransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  LOSS
  RETURN
}

model ProductSale {
  id            String        @id @default(cuid())
  dairyId       String
  dairy         Dairy         @relation(fields: [dairyId], references: [id])
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  farmerId      String?
  quantity      Float
  unitPrice     Float
  totalAmount   Float
  paymentMethod PaymentMethod
  status        SaleStatus    @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("product_sales")
}

enum SaleStatus {
  PENDING
  PAID
  CANCELLED
}

// ============================================
// STAFF ATTENDANCE
// ============================================

model Attendance {
  id        String           @id @default(cuid())
  staffId   String
  staff     Staff            @relation(fields: [staffId], references: [id])
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now())

  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HOLIDAY
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  dairyId   String
  dairy     Dairy            @relation(fields: [dairyId], references: [id])
  title     String
  message   String
  type      NotificationType
  recipient String?          // User ID if specific
  isRead    Boolean          @default(false)
  sentVia   String?          // JSON: ["WHATSAPP", "SMS", "EMAIL"]
  createdAt DateTime         @default(now())

  @@map("notifications")
}

enum NotificationType {
  BILL_GENERATED
  PAYMENT_RECEIVED
  PAYMENT_REMINDER
  LOW_STOCK
  RATE_CHANGE
  SYSTEM_ALERT
}

// ============================================
// SUBSCRIPTION PLANS
// ============================================

model Subscription {
  id           String             @id @default(cuid())
  plan         SubscriptionPlan
  status       SubscriptionStatus
  startDate    DateTime
  endDate      DateTime
  amount       Float
  currency     String             @default("INR")
  paymentId    String?
  razorpayOrderId String?
  razorpayPaymentId String?
  autoRenew    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  dairy        Dairy[]

  @@map("subscriptions")
}

enum SubscriptionPlan {
  BASIC      // ₹199/month - 300 farmers
  PREMIUM    // ₹299/month - 600 farmers
  PREMIUM_PLUS // ₹599/month - Unlimited
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

// ============================================
// REFERRAL SYSTEM (NEW - PRD v2.0)
// ============================================

model Referral {
  id              String         @id @default(cuid())
  referrerDairyId String
  referrerDairy   Dairy          @relation("ReferrerDairy", fields: [referrerDairyId], references: [id])
  referredDairyId String
  referredDairy   Dairy          @relation("ReferredDairy", fields: [referredDairyId], references: [id])
  referralCode    String         @unique
  status          ReferralStatus @default(PENDING)
  rewardDays      Int            @default(30) // Days added for referrer
  referredRewardDays Int         @default(15) // Days added for referred
  rewardedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  COMPLETED
  REWARDED
  CANCELLED
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  dairyId   String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ============================================
// OFFLINE SYNC QUEUE
// ============================================

model OfflineSyncQueue {
  id        String   @id @default(cuid())
  userId    String
  dairyId   String?
  operation String   // CREATE, UPDATE, DELETE
  table     String
  data      Json
  status    SyncStatus @default(PENDING)
  retries   Int        @default(0)
  error     String?
  createdAt DateTime   @default(now())
  syncedAt  DateTime?

  @@map("offline_sync_queue")
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}
